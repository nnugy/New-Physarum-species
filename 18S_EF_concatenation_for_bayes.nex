begin mrbayes;
log start filename = log.txt;
charset subset1 = 1-510;
charset subset2 = 511-1239\3;
charset subset3 = 512-1239\3;
charset subset4 = 513-1239\3;
partition Names = 4:subset1, subset2, subset3, subset4;
set partition=Names;
lset applyto=(1) nst=6 rates=invgamma;
lset applyto=(2) nst=2 rates=invgamma;
lset applyto=(3) nst=6 rates=invgamma;
lset applyto=(4) nst=6 rates=invgamma;

link statefreq=(all);
link revmat=(all) ;
link brlens=(all);
unlink shape=(all);

mcmcp ngen=10000000 printfreq=1000 samplefreq=1000 nchains=4 nruns=2 temp=0.1 checkpoint=yes checkfreq=5000 stoprule=yes stopval=0.01;
mcmc;
sumt conformat=Simple contype=Allcompat relburnin=yes burninfrac=0.25;
sump relburnin=yes burninfrac=0.25;
end;