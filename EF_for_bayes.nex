END;
begin mrbayes;
log start filename = log.txt;
charset subset1 = 1-729\3;
charset subset2 = 2-729\3;
charset subset3 = 3-729\3;
partition Names = 3:subset1, subset2, subset3;
set partition=Names;
lset applyto=(1) nst=2 rates=invgamma;
lset applyto=(2) nst=6 rates=invgamma;
lset applyto=(3) nst=6 rates=invgamma;
unlink statefreq=(all) revmat=(all) shape=(all) pinvar=(all) tratio=(all);
link brlens=(all);
mcmcp ngen=10000000 printfreq=1000 samplefreq=1000 nchains=4 nruns=2 temp=0.1 checkpoint=yes checkfreq=5000 stoprule=yes stopval=0.01;
mcmc;
sumt conformat=Simple contype=Allcompat relburnin=yes burninfrac=0.25;
sump relburnin=yes burninfrac=0.25;
end;
